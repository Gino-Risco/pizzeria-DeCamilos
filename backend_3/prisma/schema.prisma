  total              Decimal           @default(0) @db.Decimal(10, 2)
  activo             Boolean           @default(true)
  created_at         DateTime          @default(now()) @db.Timestamp(6)
  updated_at         DateTime          @default(now()) @db.Timestamp(6)
  observaciones      String?
  fecha_emision      DateTime          @default(dbgenerated("CURRENT_DATE")) @db.Date
  tipo_comprobante   String            @default("Nota de Venta") @db.VarChar(30)
  serie_comprobante  String?           @db.VarChar(10)
  numero_comprobante String?           @db.VarChar(20)
  igv                Decimal           @default(0) @db.Decimal(10, 2)
  metodo_pago        String?           @default("efectivo") @db.VarChar(20)
