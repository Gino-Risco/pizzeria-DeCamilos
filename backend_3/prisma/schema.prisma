generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["inventario", "pos", "public"]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model alertas_stock {
  id                                            Int       @id @default(autoincrement())
  producto_id                                   Int
  tipo_alerta                                   String    @db.VarChar(20)
  stock_en_alerta                               Decimal   @db.Decimal(10, 3)
  stock_minimo                                  Decimal   @db.Decimal(10, 3)
  referencia_tipo                               String?   @db.VarChar(50)
  referencia_id                                 Int?
  usuario_id                                    Int?
  atendida                                      Boolean   @default(false)
  atendida_por                                  Int?
  fecha_atencion                                DateTime? @db.Timestamp(6)
  created_at                                    DateTime  @default(now()) @db.Timestamp(6)
  usuarios_alertas_stock_atendida_porTousuarios usuarios? @relation("alertas_stock_atendida_porTousuarios", fields: [atendida_por], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productos                                     productos @relation(fields: [producto_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuarios_alertas_stock_usuario_idTousuarios   usuarios? @relation("alertas_stock_usuario_idTousuarios", fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_alertas_stock_fecha")
  @@index([producto_id, atendida], map: "idx_alertas_stock_producto")
  @@schema("inventario")
}

model categorias {
  id          Int         @id @default(autoincrement())
  nombre      String      @unique @db.VarChar(100)
  tipo        item_tipo?
  descripcion String?
  activo      Boolean     @default(true)
  created_at  DateTime    @default(now()) @db.Timestamp(6)
  updated_at  DateTime    @default(now()) @db.Timestamp(6)
  color       String      @default("#3b82f6")
  productos   productos[]

  @@schema("inventario")
}

